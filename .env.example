# Neon 대시보드 → 프로젝트(cloud.whoareryu) → Connect → Connection string 복사
# 반드시 콘솔에서 Tables 를 보는 것과 같은 프로젝트/브랜치(production) URL 이어야 합니다.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

GEMINI_API_KEY=your_gemini_api_key

# 서울 등 음식 상가 CSV(UTF-8). 설정 시 서버 시작마다 `restaurant` 테이블을 비우고 재적재합니다.
# 레거시 시드 테이블 `restaurants`(복수)·`daily_picks`·`restaurant_view_stats` 는
# 더 이상 ORM 에 등록되지 않으며, 필요 시 backend/scripts/drop_legacy_restaurants_tables.sql 로 삭제합니다.
# 예: C:\Users\me\Downloads\...\소상공인시장진흥공단_음식분류정보_서울_202603.csv
SGMA_RESTAURANT_CSV=
