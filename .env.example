# OpenWeatherMap — https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_CITY=Seoul

# ── star_craft Hub — DB 컨테이너 ─────────────────────────────────

# pgvector (Docker: whoareryu-pgvector) — Relational + Vector
PGVECTOR_USER=postgres
PGVECTOR_PASSWORD=your_pgvector_password
PGVECTOR_DB=whoareryu
DATABASE_URL=postgresql+asyncpg://postgres:your_pgvector_password@pgvector:5432/whoareryu

# Redis (Docker: whoareryu-redis)
REDIS_URL=redis://redis:6379/0

# Neo4j (Docker: whoareryu-neo4j)
NEO4J_USER=neo4j
NEO4J_PASSWORD=your_neo4j_password
NEO4J_URI=bolt://neo4j:7687

# n8n (Docker: whoareryu-n8n)
N8N_API_URL=http://n8n:5678
N8N_HUB_WEBHOOK_URL=http://n8n:5678/webhook/ontology
N8N_EMAIL=your_n8n_email
N8N_PASSWORD=your_n8n_password
# n8n API Key: Settings (톱니바퀴) → n8n API → Create an API key
N8N_API_KEY=your_n8n_api_key
# Gmail App Password: myaccount.google.com → 보안 → 앱 비밀번호
N8N_SMTP_PASSWORD=your_gmail_app_password

# ── GourmetMate 마이그레이션 추가분 ──────────────────────────────

# 카카오맵 REST API — 위치/지도·좌표 보정 (기획서 6-1, 월 30만건 무료)
# Kakao Developers → 앱 → REST API 키 (JavaScript 키 넣으면 401)
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# 서울 식당 기본 정보 CSV 경로 (data.go.kr 공공데이터포털, 무료)
# 폐업 정리는 영업상태명 컬럼이 있는 인허가 데이터셋(LOCALDATA형) 기준.
RESTAURANTS_CSV=/absolute/path/to/seoul_restaurants.csv

# ── Telegram Bot 알림 ─────────────────────────────────────────────
# @BotFather 에서 /newbot → 발급된 토큰 입력
TELEGRAM_BOT_TOKEN=your_telegram_bot_token
# 텔레그램 앱 → @userinfobot 에 /start 전송 → 반환된 id 값 입력
TELEGRAM_CHAT_ID=your_telegram_chat_id
