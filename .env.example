# Neon 대시보드 → 프로젝트 → Connect → Connection string
DATABASE_URL=postgresql://USER:PASSWORD@HOST/neondb?sslmode=require

# Google AI Studio — https://aistudio.google.com/apikey
GEMINI_API_KEY=your_gemini_api_key

# --- 외부 API (docs/DevOps/Backend/EXTERNAL_API_KEYS.md) ---
# Kakao Developers → 내 애플리케이션 → REST API 키
KAKAO_REST_API_KEY=your_kakao_rest_api_key

# 공공데이터포털 > 활용신청 > 지방행정 인허가 API > 요청 URL (끝에 ?serviceKey= 는 붙이지 않음)
LOCALDATA_API_URL=https://apis.data.go.kr/XXXXXXXX/localdata/getlocaldata
# 공공데이터포털 → 일반 인증키(Encoding/Decoding 키)
LOCALDATA_API_KEY=your_localdata_api_key
# (구) localdata.go.kr 직접 API — 2026년 종료. 비우고 위 URL 사용 권장.
# LOCALDATA_BASE_URL=http://www.localdata.go.kr/platform/rest/GR0/openDataApi

# OpenWeatherMap — https://home.openweathermap.org/api_keys
OPENWEATHER_API_KEY=your_openweather_api_key
OPENWEATHER_CITY=Seoul
